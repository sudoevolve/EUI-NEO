include_guard(GLOBAL)

function(eui_resolve_harfbuzz)
    if(TARGET harfbuzz::harfbuzz)
        return()
    endif()

    find_package(harfbuzz CONFIG QUIET)
    if(NOT TARGET harfbuzz::harfbuzz)
        find_package(HarfBuzz QUIET)
    endif()
    if(TARGET harfbuzz::harfbuzz)
        return()
    endif()
    if(TARGET harfbuzz)
        add_library(harfbuzz::harfbuzz ALIAS harfbuzz)
        return()
    endif()

    eui_begin_pkg_config_cache_guard()
    find_package(PkgConfig QUIET)
    if(PkgConfig_FOUND)
        pkg_check_modules(EUI_HARFBUZZ QUIET IMPORTED_TARGET harfbuzz)
    endif()
    eui_end_pkg_config_cache_guard()
    if(TARGET PkgConfig::EUI_HARFBUZZ)
        eui_create_forward_target(harfbuzz::harfbuzz PkgConfig::EUI_HARFBUZZ)
        return()
    endif()

    eui_fetch_allowed(_can_fetch EUI_FETCH_HARFBUZZ)
    if(_can_fetch)
        eui_require_cpm()
        eui_set_third_party_option(HB_HAVE_CAIRO OFF "Disable Cairo support in HarfBuzz")
        eui_set_third_party_option(HB_HAVE_GRAPHITE2 OFF "Disable Graphite2 support in HarfBuzz")
        eui_set_third_party_option(HB_HAVE_GLIB OFF "Disable GLib support in HarfBuzz")
        eui_set_third_party_option(HB_HAVE_GOBJECT OFF "Disable GObject support in HarfBuzz")
        eui_set_third_party_option(HB_HAVE_ICU OFF "Disable ICU support in HarfBuzz")
        eui_set_third_party_option(HB_HAVE_INTROSPECTION OFF "Disable introspection support in HarfBuzz")
        eui_set_third_party_option(HB_BUILD_UTILS OFF "Disable HarfBuzz utility tools")
        eui_set_third_party_option(HB_BUILD_SUBSET OFF "Disable HarfBuzz subset library")
        CPMAddPackage(
            NAME eui_harfbuzz_source
            URL https://github.com/harfbuzz/harfbuzz/archive/refs/tags/8.5.0.zip
            DOWNLOAD_ONLY YES
            DOWNLOAD_EXTRACT_TIMESTAMP TRUE
        )
        eui_begin_quiet_third_party_config()
        add_subdirectory("${eui_harfbuzz_source_SOURCE_DIR}" "${CMAKE_CURRENT_BINARY_DIR}/_deps/harfbuzz-build" EXCLUDE_FROM_ALL)
        eui_end_quiet_third_party_config()
        if(TARGET harfbuzz AND NOT TARGET harfbuzz::harfbuzz)
            add_library(harfbuzz::harfbuzz ALIAS harfbuzz)
        endif()
        if(TARGET harfbuzz)
            eui_silence_third_party_warnings(harfbuzz)
        endif()
        if(MSVC AND TARGET harfbuzz)
            target_compile_options(harfbuzz PRIVATE /utf-8)
        endif()
        set(CMAKE_CXX_STANDARD 17)
        set(CMAKE_CXX_STANDARD_REQUIRED TRUE)
        if(TARGET harfbuzz::harfbuzz)
            return()
        endif()
    endif()

    eui_missing_dependency("HarfBuzz" "EUI_FETCH_HARFBUZZ" "Disable shaping with -DEUI_ENABLE_HARFBUZZ=OFF if it is not needed.")
endfunction()
